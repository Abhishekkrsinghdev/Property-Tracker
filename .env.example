# ============================================================
# PropTrack AI — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# ── Database ─────────────────────────────────────────────────
DB_PASSWORD=choose_a_strong_password_here

# ── JWT ──────────────────────────────────────────────────────
# Must be at least 32 characters (256 bits) for HS256
JWT_SECRET=replace_with_a_long_random_string_at_least_32_chars

# ── Anthropic (Claude API) ────────────────────────────────────
# Get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Email (Resend) ────────────────────────────────────────────
# Get from https://resend.com — free tier: 3,000 emails/month
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ── File Storage ──────────────────────────────────────────────
# Set to 'local' (default) to store files on the server disk inside Docker volume.
# Set to 's3' to use any S3-compatible service (AWS S3, Supabase Storage, Cloudflare R2).
APP_STORAGE_PROVIDER=local

# Only required when APP_STORAGE_PROVIDER=s3
# --- AWS S3 ---
# APP_STORAGE_S3_ENDPOINT=            # Leave blank for real AWS S3
# APP_STORAGE_S3_REGION=ap-south-1
# APP_STORAGE_S3_ACCESS_KEY=...
# APP_STORAGE_S3_SECRET_KEY=...
# APP_STORAGE_S3_BUCKET=proptrack
# APP_STORAGE_S3_PUBLIC_URL_PREFIX=https://proptrack.s3.ap-south-1.amazonaws.com

# --- Supabase Storage (S3-compatible) ---
# APP_STORAGE_S3_ENDPOINT=https://<project-ref>.supabase.co/storage/v1/s3
# APP_STORAGE_S3_REGION=ap-south-1
# APP_STORAGE_S3_ACCESS_KEY=<supabase-access-key>
# APP_STORAGE_S3_SECRET_KEY=<supabase-secret-key>
# APP_STORAGE_S3_BUCKET=proptrack
# APP_STORAGE_S3_PUBLIC_URL_PREFIX=https://<project-ref>.supabase.co/storage/v1/object/public/proptrack

# ── Service URLs (override for local dev if needed) ───────────
# These defaults work as-is with docker-compose
# AI_SERVICE_URL=http://fastapi:8000
# DB_URL=jdbc:postgresql://postgres:5432/proptrack